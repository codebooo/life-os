<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application>
        <!-- Opt-in macro engine (§Module 12): user must enable it explicitly in
             system accessibility settings; nothing runs without a per-macro
             confirmation in the app. -->
        <service
            android:name="com.lifeos.feature.agentic.engine.LifeAccessibilityService"
            android:exported="false"
            android:label="LifeOS Macros"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/lifeos_accessibility_config" />
        </service>
    </application>

</manifest>
